# Frontend (Vite) — copy to ".env.local" for local overrides (do not commit secrets).
# See docs/runbooks/environment-configuration.md

# Optional: absolute API base for the browser. Leave unset to use same-origin /v1 (Vite proxy).
# VITE_API_BASE_URL=http://127.0.0.1:8765

# Dev/build-time only (read by vite.config.ts for proxy target; not bundled into the client).
# AGENTIUM_CONTROL_PLANE_URL=http://127.0.0.1:8765
