# Agentium — TEMPLATE ONLY. Runtime never reads this file.
# Copy to ".env" in this repo root (same folder as pyproject.toml), uncomment keys you need,
# then restart the control plane. Putting secrets only here has NO effect.
# Authoritative field list & defaults: src/agentium/app/settings.py (AppSettings).
# See docs/runbooks/environment-configuration.md

# --- Profile ---
# AGENTIUM_PROFILE=dev

# --- HTTP ---
# AGENTIUM_HTTP_HOST=127.0.0.1
# AGENTIUM_HTTP_PORT=8765

# --- Paths ---
# AGENTIUM_DATA_DIR=.agentium_data
# AGENTIUM_POLICY_PATH=
# AGENTIUM_PLUGINS_CONFIG=

# --- Governance / manifests ---
# AGENTIUM_REQUIRE_RUN_MANIFEST=
# AGENTIUM_EXPECTED_RUN_MANIFEST_SHA256=
# AGENTIUM_APPROVAL_TTL_SECONDS=
# AGENTIUM_DOMAIN_PACKS_ROOT=

# --- Skills ---
# AGENTIUM_SKILLS_ROOT=

# --- Identity (Bearer/OIDC) ---
# AGENTIUM_IDENTITY_MODE=hybrid
# AGENTIUM_OIDC_ISSUERS_JSON=

# --- Persistence backends ---
# AGENTIUM_APPROVAL_BACKEND=memory
# AGENTIUM_AUDIT_BACKEND=memory

# --- Models / DeepSeek ---
# AGENTIUM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# AGENTIUM_DEEPSEEK_API_KEY=
# AGENTIUM_CHAT_MODEL=deepseek-v4
# AGENTIUM_CHAT_COMPLETION_TIMEOUT_SECONDS=120

# --- Background plane ---
# AGENTIUM_BACKGROUND_ENABLED=
# AGENTIUM_BACKGROUND_INTERVAL_SECONDS=30
# AGENTIUM_BACKGROUND_NOISE_RPS_PAUSE=0

# --- Telemetry & dashboards ---
# AGENTIUM_TELEMETRY=null
# AGENTIUM_GRAFANA_BASE_URL=
# AGENTIUM_TEMPO_BASE_URL=

# --- Tenant defaults ---
# AGENTIUM_DEFAULT_TENANT_TOKEN_LIMIT=100000
# AGENTIUM_DEFAULT_TENANT_COST_LIMIT=1000
# AGENTIUM_DEFAULT_TENANT_MAX_CONCURRENCY=8

# --- Emergence / outbound guards ---
# AGENTIUM_EMERGENCE_NODE_WARN=200
# AGENTIUM_EMERGENCE_NODE_HARD=500
# AGENTIUM_EMERGENCE_OUTBOUND_WARN=30
# AGENTIUM_EMERGENCE_OUTBOUND_HARD=60
# AGENTIUM_OUTBOUND_RATE_LIMIT_PER_MINUTE=60

# --- Policy bundle release verification ---
# AGENTIUM_POLICY_RELEASE_HMAC_SECRET=

# --- Dev tooling ---
# AGENTIUM_LSP_UPSTREAM_URL=

# --- OpenTelemetry (standard names; optional when AGENTIUM_TELEMETRY=otel) ---
# OTEL_SERVICE_NAME=agentium-control-plane
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
