{
  "name": "agentium-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:web": "tsc -p tsconfig.json --noEmit && vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "reinstall-electron": "node scripts/reinstall-electron.mjs",
    "reinstall-electron:cn": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ node scripts/reinstall-electron.mjs",
    "build": "npm run build:web && npm run build:electron",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "dev:desktop": "npm run build:electron && concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 node ./node_modules/electron/cli.js .\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "i18next": "^24.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "reactflow": "^11.11.4",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.5.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.4.2",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@4.34.9"
  }
}
