# Agentium — TEMPLATE ONLY. Runtime never reads this file.
# Copy to ".env" in this repo root (same folder as pyproject.toml), uncomment keys you need,
# then restart the control plane. Putting secrets only here has NO effect.
# Authoritative field list & defaults: src/agentium/app/settings.py (AppSettings).
# See docs/runbooks/environment-configuration.md

# --- Profile ---
# AGENTIUM_PROFILE=dev

# --- HTTP ---
# AGENTIUM_HTTP_HOST=127.0.0.1
# AGENTIUM_HTTP_PORT=8765

# --- Paths ---
# AGENTIUM_DATA_DIR=.agentium_data
# AGENTIUM_POLICY_PATH=
# AGENTIUM_PLUGINS_CONFIG=

# --- LLM-Wiki (crate) ---
# Enables without editing YAML: 1/true/yes/on (or 0/false/off to FORCE OFF even if YAML says true).
# WARNING: `AGENTIUM_LLM_WIKI_ENABLED=0` or `false` turns LLM Wiki OFF and overrides `llm_wiki.enabled`
# in runtime_plugins YAML. Omit this variable locally unless you intentionally want env-level control.
# AGENTIUM_LLM_WIKI_ENABLED=1

# --- Logging (agentium serve; daily rotate at local midnight) ---
# Default file is logs/agentium.log relative to process working directory.
# AGENTIUM_LOG_FILE=logs/agentium.log
# Set empty to disable file logging: AGENTIUM_LOG_FILE=
# AGENTIUM_LOG_BACKUP_COUNT=14
# AGENTIUM_LOG_CONSOLE=1

# --- Governance / manifests ---
# AGENTIUM_REQUIRE_RUN_MANIFEST=
# AGENTIUM_EXPECTED_RUN_MANIFEST_SHA256=
# AGENTIUM_APPROVAL_TTL_SECONDS=
# AGENTIUM_DOMAIN_PACKS_ROOT=

# --- Skills ---
# AGENTIUM_SKILLS_ROOT=

# --- Identity (Bearer/OIDC) ---
# AGENTIUM_IDENTITY_MODE=hybrid
# AGENTIUM_OIDC_ISSUERS_JSON=

# --- Persistence backends ---
# AGENTIUM_APPROVAL_BACKEND=memory
# AGENTIUM_AUDIT_BACKEND=memory

# --- Models / DeepSeek ---
# AGENTIUM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# AGENTIUM_DEEPSEEK_API_KEY=
# AGENTIUM_CHAT_MODEL=deepseek-v4-flash
# Alternative V4 tier: deepseek-v4-pro
# AGENTIUM_CHAT_COMPLETION_TIMEOUT_SECONDS=120
# AGENTIUM_CHAT_TOOL_DESCRIPTION_MAX_CHARS=512
# AGENTIUM_TOOL_CONTRACT_MIN_DESCRIPTION_CHARS=12

# --- Chat context budget & prompt cache telemetry ---
# AGENTIUM_CHAT_CONTEXT_BUDGET=1
# AGENTIUM_CHAT_CONTEXT_SOFT_TOKENS=24000
# AGENTIUM_CHAT_CONTEXT_HARD_TOKENS=48000
# AGENTIUM_CHAT_CONTEXT_SAFE_DEGRADE=1
# AGENTIUM_PROMPT_CACHE_TELEMETRY=1
# AGENTIUM_PROMPT_CACHE_HTTP_HEADER=0

# --- Tool auto-approval (chat agent loop) ---
# AGENTIUM_TOOL_APPROVAL_AUTO=0
# AGENTIUM_TOOL_APPROVAL_CLASSIFIER_MODEL=
# AGENTIUM_TOOL_APPROVAL_MAX_AUTO_DENIES_PER_TURN=3
# AGENTIUM_TOOL_APPROVAL_ON_FAULT=pending_human
# AGENTIUM_TOOL_APPROVAL_RULE_DENY_TOOLS=
# AGENTIUM_TOOL_APPROVAL_DENY_SHELL_PATTERN=

# --- Sandbox MVP (path / egress hints via request metadata) ---
# AGENTIUM_SANDBOX_PATH_ALLOWLIST=
# AGENTIUM_SANDBOX_EGRESS_DENY_DEFAULT=0
# AGENTIUM_SANDBOX_EGRESS_ALLOW_HOSTS=

# --- Background plane ---
# AGENTIUM_BACKGROUND_ENABLED=
# AGENTIUM_BACKGROUND_INTERVAL_SECONDS=30
# AGENTIUM_BACKGROUND_NOISE_RPS_PAUSE=0

# --- Telemetry & dashboards ---
# AGENTIUM_TELEMETRY=null
# AGENTIUM_GRAFANA_BASE_URL=
# AGENTIUM_TEMPO_BASE_URL=

# --- Tenant defaults ---
# AGENTIUM_DEFAULT_TENANT_TOKEN_LIMIT=100000
# AGENTIUM_DEFAULT_TENANT_COST_LIMIT=1000
# AGENTIUM_DEFAULT_TENANT_MAX_CONCURRENCY=8

# --- Emergence / outbound guards ---
# AGENTIUM_EMERGENCE_NODE_WARN=200
# AGENTIUM_EMERGENCE_NODE_HARD=500
# AGENTIUM_EMERGENCE_OUTBOUND_WARN=30
# AGENTIUM_EMERGENCE_OUTBOUND_HARD=60
# AGENTIUM_OUTBOUND_RATE_LIMIT_PER_MINUTE=60

# --- Policy bundle release verification ---
# AGENTIUM_POLICY_RELEASE_HMAC_SECRET=

# --- Dev tooling ---
# AGENTIUM_LSP_UPSTREAM_URL=

# --- Chat ingress (collect / followup / steer queues; optional) ---
# AGENTIUM_CHAT_INGRESS_BACKEND=off
# AGENTIUM_CHAT_INGRESS_DEBOUNCE_MS=500
# AGENTIUM_CHAT_INGRESS_QUEUE_CAP=20
# AGENTIUM_CHAT_INGRESS_LEASE_TTL_SECONDS=600
# AGENTIUM_CHAT_INGRESS_REDIS_KEY_PREFIX=agentium:ingress
# AGENTIUM_CHAT_INGRESS_REDIS_URL=
# AGENTIUM_CHAT_INGRESS_DATABASE_URL=
# AGENTIUM_CHAT_INGRESS_SQLITE_PATH=
# Optional: run Postgres ingress integration tests (not read by runtime):
# AGENTIUM_CHAT_INGRESS_TEST_DATABASE_URL=postgresql://...

# --- Task lock / harness (P2; off by default) ---
# AGENTIUM_FEATURE_TASK_LOCK=0
# AGENTIUM_TASK_LOCK_SQLITE_PATH=
# AGENTIUM_TASK_LOCK_MAX_TTL_SECONDS=3600
# AGENTIUM_HARNESS_ORACLE_ENABLED=0
# AGENTIUM_HARNESS_PARALLEL_WORKERS_MAX=8
# AGENTIUM_STRICT_HARNESS_HANDOFF=0
# AGENTIUM_EXECUTION_TIER_HIGH_RISK_GATE=0

# --- OpenTelemetry (standard names; optional when AGENTIUM_TELEMETRY=otel) ---
# OTEL_SERVICE_NAME=agentium-control-plane
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
